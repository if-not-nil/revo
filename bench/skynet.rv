let start = time.now()

fn skynet(num, size) do
  if size <= 1 return num
  size /= 10
  let acc = 0
  for i in 0..10 do
    let child = spawn skynet(num + i * size, size)
    acc += join(child)
  end
  acc
end

let root = spawn skynet(0, 1000000)
print("Res:", join(root))
print!("took %v", (time.now() - start)/1000)
