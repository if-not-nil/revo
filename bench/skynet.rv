fn skynet(num, size) do
  print(type(skynet), "a")
  if size == 1 return num
  size /= 10
  let acc = 0
  for i in 0..10 do
    print(type(skynet), "b")
    let child = spawn skynet(num + i * size, size)
    acc += join(child)
  end
  acc
end


print(type(skynet))
let root = spawn skynet(0, 2)
print("Res:", join(root))
print(type(skynet))
